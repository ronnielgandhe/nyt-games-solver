{
  "manifest_version": 3,
  "name": "NYT Games Solver",
  "version": "1.0.0",
  "description": "Instantly solve NYT games — Wordle, Connections, Mini Crossword, Strands & Spelling Bee",
  "permissions": ["activeTab", "scripting", "debugger"],
  "host_permissions": ["https://*.nytimes.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
